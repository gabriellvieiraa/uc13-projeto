// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  DIRECTOR
}

enum UserStatus {
  ATIVO
  INATIVO
}

model User {
  id                Int             @id @default(autoincrement())
  type              UserType?
  name              String
  cpf               String          @unique
  email             String          @unique
  status            UserStatus?
  birthDate         DateTime?       @map("birth_date")
  password          String          @default("123")



  companyId         Int?            @map("company_id")
  company           Company?        @relation(fields: [companyId], references: [id])
  
  categories        Category[]      @relation("user_category") 
  coursesOwned      Course[]        @relation("course_owner")

  companiesOwned    Company[]       @relation("company_owner")

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("users")
}


model Company {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  cnpj          String        @unique
  foundation    DateTime      
  places        String
  fundaments    String
  methods       String

  users         User[]       
  courses       Course[]    

  ownerId       Int?          @map("owner_id")
  owner         User?         @relation("company_owner", fields: [ownerId], references: [id])


  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}


model Category {
  id                Int         @id @default(autoincrement())
  name              String      @unique
  description       String
  courses           Course[]    @relation("category_course")
  users             User[]      @relation("user_category") 
  
  @@map("categories")

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  
}




model Course{
  id             Int         @id @default(autoincrement())
  name           String      
  description    String
  urlImg         String      @map("url_img") @default("")
  workload       Float?
  ranking        Int
  fieldOfStudy   String     @map("Field_of_study")
   
  categories     Category[]  @relation("category_course")
  companyId       Int        @map("company_id")
  company       Company    @relation(fields: [companyId], references: [id])

  ownerId       Int?       @map("owner_id")
  owner         User?      @relation("course_owner", fields: [ownerId], references: [id])

  
  @@map("courses")



  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

}